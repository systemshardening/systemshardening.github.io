{# Reusable article card for listing pages #}
{# Usage: {% set article = item %}{% include "article-meta.njk" %} #}
<div class="article-card">
  <a href="{{ article.url }}">
    <h3>{{ article.data.title }}</h3>
  </a>
  <div class="article-card-meta">
    <span class="article-category">{{ article.data.category | categoryName }}</span>
    {% if article.data.difficulty %}
      <span class="article-difficulty">{{ article.data.difficulty }}</span>
    {% endif %}
    {% if article.data.estimated_reading_time %}
      <span class="article-reading-time">{{ article.data.estimated_reading_time }} min</span>
    {% endif %}
  </div>
  {% if article.data.tags %}
    <div class="article-tags">
      {% for tag in article.data.tags | slice(0, 4) %}
        <span class="tag">{{ tag }}</span>
      {% endfor %}
    </div>
  {% endif %}
</div>
